# Custom Client ID and Secret
# Copy this file as .env and set your app ID and secret here

NUXT_APP_CLIENT_ID_FULL=your_full_access_client_id_here
NUXT_APP_CLIENT_SECRET_FULL=your_full_access_client_secret_here
NUXT_APP_CLIENT_ID_APP_FOLDER=your_app_folder_client_id_here
NUXT_APP_CLIENT_SECRET_APP_FOLDER=your_app_folder_client_secret_here
NUXT_SESSION_PASSWORD=your_session_password_here

